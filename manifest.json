{
  "background": {
    "service_worker": "js/backgroundpage.js"
  },
  "default_locale": "en",
  "content_scripts": [
    {
      "run_at": "document_start",
      "css": [
        "css/fontawesome/fontawesome.min.css",
        "css/general.css",
        "css/night.css"
      ],
      "js": [
        "js/utils-enhanced.js",
        "js/core/i18n.js",
        "js/core/steam-community.js",
        "js/core/settings-store.js",
        "js/core/settings-actions.js",
        "js/core/giveaway.js",
        "js/core/page-enhancements.js",
        "js/core/autoentry-steam-data.js",
        "js/core/autoentry-giveaway.js",
        "js/autoentry.js",
        "js/settings.js",
        "js/suspension-notice.js"
      ],
      "matches": [
        "*://www.steamgifts.com/",
        "*://www.steamgifts.com/giveaways/search?*",
        "*://www.steamgifts.com/game/*",
        "*://steamgifts.com/",
        "*://steamgifts.com/giveaways/search?*",
        "*://steamgifts.com/game/*"
      ]
    },
    {
      "css": [
        "css/fontawesome/fontawesome.min.css",
        "css/general.css",
        "css/night.css"
      ],
      "js": ["js/utils-enhanced.js", "js/core/page-enhancements.js"],
      "matches": [
        "*://steamgifts.com/giveaways/created/*",
        "*://www.steamgifts.com/giveaways/created/*",
        "*://steamgifts.com/giveaways/entered/*",
        "*://www.steamgifts.com/giveaways/entered/*",
        "*://steamgifts.com/giveaways/won/*",
        "*://www.steamgifts.com/giveaways/won/*",
        "*://steamgifts.com/trades/*",
        "*://www.steamgifts.com/trades/*",
        "*://steamgifts.com/sales/*",
        "*://www.steamgifts.com/sales/*",
        "*://steamgifts.com/discussions/*",
        "*://www.steamgifts.com/discussions/*",
        "*://steamgifts.com/discussion/*",
        "*://www.steamgifts.com/discussion/*",
        "*://steamgifts.com/about/*",
        "*://www.steamgifts.com/about/*",
        "*://steamgifts.com/support/*",
        "*://www.steamgifts.com/support/*",
        "*://steamgifts.com/messages/*",
        "*://www.steamgifts.com/messages/*",
        "*://steamgifts.com/account/*",
        "*://www.steamgifts.com/account/*",
        "*://steamgifts.com/trade/*",
        "*://www.steamgifts.com/trade/*",
        "*://steamgifts.com/users/*",
        "*://www.steamgifts.com/users/*",
        "*://steamgifts.com/user/*",
        "*://www.steamgifts.com/user/*",
        "*://steamgifts.com/giveaway/*",
        "*://www.steamgifts.com/giveaway/*",
        "*://steamgifts.com/legal/*",
        "*://www.steamgifts.com/legal/*"
      ]
    }
  ],
  "icons": {
    "128": "media/autologo.png",
    "16": "media/autologo16.png",
    "32": "media/autologo32.png",
    "48": "media/autologo48.png"
  },
  "manifest_version": 3,
  "name": "AutoJoin for SteamGifts",
  "short_name": "AutoJoin",
  "description": "Enhanced AutoJoin for SteamGifts with modern UI, improved accessibility, and optimized performance",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "offscreen",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://www.steamgifts.com/*",
    "*://store.steampowered.com/*"
  ],
  "optional_host_permissions": ["*://steamcommunity.com/profiles/*"],
  "version": "2.0.1",
  "web_accessible_resources": [
    {
      "use_dynamic_url": true,
      "resources": [
        "html/settings.html",
        "css/night.css",
        "css/fontawesome/fontawesome.min.css",
        "css/fontawesome/webfonts/fa-brands-400.woff2",
        "css/fontawesome/webfonts/fa-brands-400.ttf",
        "css/fontawesome/webfonts/fa-regular-400.woff2",
        "css/fontawesome/webfonts/fa-regular-400.ttf",
        "css/fontawesome/webfonts/fa-solid-900.woff2",
        "css/fontawesome/webfonts/fa-solid-900.ttf",
        "css/fontawesome/webfonts/fa-v4compatibility.woff2",
        "css/fontawesome/webfonts/fa-v4compatibility.ttf",
        "media/autologo.png",
        "media/audio.mp3"
      ],
      "matches": ["*://steamgifts.com/*", "*://www.steamgifts.com/*"],
      "extension_ids": []
    }
  ],
  "options_ui": {
    "page": "html/settings.html",
    "open_in_tab": true
  }
}
